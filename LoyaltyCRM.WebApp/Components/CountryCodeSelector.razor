
<select class="form-select" style="max-width: 120px;" value="@SelectedCountryCode" @onchange="OnChange">
    @foreach (var countryCode in CountryCodes)
    {
        <option value="@countryCode.Value">@countryCode.Key (@countryCode.Value)</option>
    }
</select>

@code {
    [Parameter]
    public string SelectedCountryCode { get; set; } = "+45"; // Default to Denmark

    [Parameter]
    public EventCallback<string> SelectedCountryCodeChanged { get; set; }

    private async Task OnChange(ChangeEventArgs e)
    {
        SelectedCountryCode = e?.Value?.ToString() ?? SelectedCountryCode;
        await SelectedCountryCodeChanged.InvokeAsync(SelectedCountryCode);
    }

