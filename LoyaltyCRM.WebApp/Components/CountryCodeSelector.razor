<div class="dropdown country-code-dropdown" style="position:relative; min-width:120px;">
    <button type="button"
            class="btn btn-outline-secondary dropdown-toggle d-flex align-items-center gap-2"
            @onclick="ToggleDropdown"
            aria-expanded="@IsOpen">
        @if (!string.IsNullOrEmpty(GetFlagUrl(SelectedCountryCode)))
        {
            <img src="@GetFlagUrl(SelectedCountryCode)" alt="Country flag" style="width:22px; height:16px; object-fit:contain;" />
        }
        <span>@SelectedCountryCode</span>
    </button>

    <ul class="dropdown-menu @((IsOpen) ? "show" : "")" style="max-height:280px; overflow:auto;">
        @foreach (var country in Countries)
        {
            <li>
                <button type="button"
                        class="dropdown-item d-flex align-items-center gap-2 @(country.DialCode == SelectedCountryCode ? "active" : "")"
                        @onclick="() => SelectCountryCode(country.DialCode)">
                    @if (!string.IsNullOrEmpty(GetFlagUrl(country.Name)))
                    {
                        <img src="@GetFlagUrl(country.Name)" alt="@country.Name flag" style="width:20px; height:14px; object-fit:contain;" />
                    }
                    <span>@country.Name</span>
                </button>
            </li>
        }
    </ul>
</div>

@code {
    [Parameter]
    public string SelectedCountryCode { get; set; } = "+45"; // Default to Denmark

    [Parameter]
    public EventCallback<string> SelectedCountryCodeChanged { get; set; }

    private bool IsOpen { get; set; }

    private void ToggleDropdown()
    {
        IsOpen = !IsOpen;
    }

    private async Task SelectCountryCode(string selected)
    {
        SelectedCountryCode = selected;
        IsOpen = false;
        await SelectedCountryCodeChanged.InvokeAsync(SelectedCountryCode);
    }

    private static string? GetFlagUrl(string countryNameOrCode)
        => GetFlagIsoCode(countryNameOrCode) is string isoCode
            ? $"/icons/flags/{isoCode}.png"
            : null;

    private static string? GetFlagIsoCode(string countryNameOrCode)
    {
        if (string.IsNullOrWhiteSpace(countryNameOrCode))
        {
            return null;
        }

        countryNameOrCode = countryNameOrCode.Trim();

        if (countryNameOrCode.StartsWith("+"))
        {
            return Countries.FirstOrDefault(c => c.DialCode == countryNameOrCode)?.Iso;
        }

        return Countries.FirstOrDefault(c => string.Equals(c.Name, countryNameOrCode, StringComparison.OrdinalIgnoreCase))?.Iso;
    }

