@page "/login"
@inject AuthService AuthService
@inject NavigationManager Navigation
@using LoyaltyCRM.DTOs.Requests.Auth
@using LoyaltyCRM.WebApp.Components
@using LoyaltyCRM.WebApp.Locales
@inject IStringLocalizer<Resources> L

<div class="wrapper d-flex flex-column align-items-center justify-content-center min-vh-100">
    <div class="card shadow-sm p-4" style="max-width: 350px; width: 100%;">
        <h3 class="text-center mb-4">@L["Login.Title"]</h3>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger text-center">@errorMessage</div>
        }

        <EditForm Model="@loginDto" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">@L["Login.Username"]</label>
                <InputText @bind-Value="loginDto.UserName" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">@L["Login.Password"]</label>
                <InputText @bind-Value="loginDto.Password" type="password" class="form-control" />
            </div>
            <button class="btn btn-primary w-100 mt-2" type="submit">@L["Navigation.Login"]</button>
        </EditForm>
    </div>
</div>

@code {
    private LoginRequest loginDto = new LoginRequest();
    private string errorMessage = string.Empty;

    private string path = "/yearcard/create";

    private async Task HandleLogin()
    {
        var result = await AuthService.LoginAsync(loginDto);
        if (result.Success)
        {
            Navigation.NavigateTo(path);
        }
        else
        {
            errorMessage = result.ErrorMessage;
        }
    }
}
