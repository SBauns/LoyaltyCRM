@page "/admin"

@using LoyaltyCRM.DTOs.DTOs
@using LoyaltyCRM.WebApp.Components
@using LoyaltyCRM.WebApp.Locales
@inject AuthService AuthService
@inject SettingsService SettingsService
@inject HttpClient Http
@inject IStringLocalizer<Resources> L

<div class="create-wrapper d-flex flex-column align-items-center justify-content-center min-vh-100">
    <div class="card shadow-sm p-4 w-100" style="max-width: 820px;">
        <h3 class="text-center mb-3">@L["Admin Panel"]</h3>

        <div class="btn-group w-100 mb-4" role="group">
            <button class="btn @GetTabClass(AdminSection.PasswordSettings)" @onclick="() => ChangeSection(AdminSection.PasswordSettings)">@L["Password settings"]</button>
            <button class="btn @GetTabClass(AdminSection.TermsSetting)" @onclick="() => ChangeSection(AdminSection.TermsSetting)">@L["Terms setting"]</button>
            <button class="btn @GetTabClass(AdminSection.AppSettings)" @onclick="() => ChangeSection(AdminSection.AppSettings)">@L["App settings"]</button>
        </div>

        @if (CurrentSection == AdminSection.PasswordSettings)
        {
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <h5 class="text-center">@L["Admin"]</h5>
                    <EditForm Model="@adminPasswordModel" OnValidSubmit="ChangeAdminPassword">
                        <DataAnnotationsValidator />
                        <ValidationSummary />
                        <div class="mb-3">
                            <label for="adminUserName" class="form-label">@L["Admin Username:"]</label>
                            <InputText id="adminUserName" class="form-control" @bind-Value="adminPasswordModel.UserName" />
                        </div>
                        <div class="mb-3">
                            <label for="adminCurrentPassword" class="form-label">@L["Current Password:"]</label>
                            <InputText id="adminCurrentPassword" class="form-control" @bind-Value="adminPasswordModel.CurrentPassword" type="password" />
                        </div>
                        <div class="mb-3">
                            <label for="adminNewPassword" class="form-label">@L["New Password:"]</label>
                            <InputText id="adminNewPassword" class="form-control" @bind-Value="adminPasswordModel.NewPassword" type="password" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100 mt-2">@L["Change Password"]</button>
                        @if (!string.IsNullOrEmpty(adminPasswordMessage))
                        {
                            <div class="alert mt-2 @(adminPasswordSuccess ? "alert-success" : "alert-danger") text-center">@adminPasswordMessage</div>
                        }
                    </EditForm>
                </div>
                <div class="col-12 col-md-6">
                    <h5 class="text-center">@L["Bartender"]</h5>
                    <EditForm Model="@bartenderPasswordModel" OnValidSubmit="ChangeBartenderPassword">
                        <DataAnnotationsValidator />
                        <ValidationSummary />
                        <div class="mb-3">
                            <label for="bartenderUserName" class="form-label">@L["Bartender Username:"]</label>
                            <InputText id="bartenderUserName" class="form-control" @bind-Value="bartenderPasswordModel.UserName" />
                        </div>
                        <div class="mb-3">
                            <label for="bartenderCurrentPassword" class="form-label">@L["Current Password:"]</label>
                            <InputText id="bartenderCurrentPassword" class="form-control" @bind-Value="bartenderPasswordModel.CurrentPassword" type="password" />
                        </div>
                        <div class="mb-3">
                            <label for="bartenderNewPassword" class="form-label">@L["New Password:"]</label>
                            <InputText id="bartenderNewPassword" class="form-control" @bind-Value="bartenderPasswordModel.NewPassword" type="password" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100 mt-2">@L["Change Password"]</button>
                        @if (!string.IsNullOrEmpty(bartenderPasswordMessage))
                        {
                            <div class="alert mt-2 @(bartenderPasswordSuccess ? "alert-success" : "alert-danger") text-center">@bartenderPasswordMessage</div>
                        }
                    </EditForm>
                </div>
            </div>
        }
        else if (CurrentSection == AdminSection.TermsSetting)
        {
            <div class="mb-3 d-flex gap-2 justify-content-center">
                <button class="btn btn-sm @(BoldActive ? "btn-primary" : "btn-outline-secondary")" @onclick="ExecBold">@L["Bold"]</button>
                <button class="btn btn-sm @(BulletsActive ? "btn-primary" : "btn-outline-secondary")" @onclick="ExecBullets">@L["Bullets"]</button>
                <button class="btn btn-sm btn-primary" @onclick="SaveTermsToServer">@L["Save"]</button>
                <button class="btn btn-sm btn-outline-danger" @onclick="ClearTerms">@L["Clear"]</button>
            </div>
            @if (!string.IsNullOrEmpty(editorMessage))
            {
                <div class="alert mt-2 @(editorSuccess ? "alert-success" : "alert-danger") text-center">@editorMessage</div>
            }
            <div id="termsEditor" contenteditable="true" class="border rounded p-3" style="min-height:240px; overflow:auto;">
                <!-- Edit terms here. Use Bold and Bullets to format. -->
            </div>
        }
        else if (CurrentSection == AdminSection.AppSettings)
        {
            <div class="mb-3 text-center text-muted">
                @L["Configure app settings using only numeric values. These are validated before saving."]
            </div>
            @if (!string.IsNullOrEmpty(appSettingsMessage))
            {
                <div class="alert mt-2 @(appSettingsSuccess ? "alert-success" : "alert-danger") text-center">@appSettingsMessage</div>
            }
            <div class="row g-3">
                @foreach (var setting in appSettings)
                {
                    <div class="col-12 col-md-4">
                        <label class="form-label">@FormatSettingLabel(setting.Key)</label>
                        <InputText class="form-control" @bind-Value="setting.Value" />
                    </div>
                }
            </div>
            <div class="d-flex justify-content-end mt-3">
                <button class="btn btn-primary" @onclick="SaveAppSettings">@L["Save App Settings"]</button>
            </div>
        }
    </div>
</div>

@code {
    private enum AdminSection
    {
        PasswordSettings,
        TermsSetting,
        AppSettings
    }

    private AdminSection CurrentSection = AdminSection.PasswordSettings;

    private AuthService.ChangePasswordDto adminPasswordModel = new AuthService.ChangePasswordDto();
    private AuthService.ChangePasswordDto bartenderPasswordModel = new AuthService.ChangePasswordDto();
    private string adminPasswordMessage = string.Empty;
    private string bartenderPasswordMessage = string.Empty;
    private bool adminPasswordSuccess = false;
    private bool bartenderPasswordSuccess = false;

    private readonly string[] KnownKeys = new[]
    {
        "LengthOfYearcardInDays",
        "DiscountGracePeriodInDays",
        "TimeBeforeDeleteInvalidYearcard",
        "TimeToCleanUpCards"
    };

    private readonly Dictionary<string, string> SettingLabels = new(StringComparer.OrdinalIgnoreCase)
    {
        ["LengthOfYearcardInDays"] = "Length of yearcard (days)",
        ["DiscountGracePeriodInDays"] = "Discount grace period (days)",
        ["TimeBeforeDeleteInvalidYearcard"] = "Delete invalid yearcard after (days)",
        ["TimeToCleanUpCards"] = "Time of Day to Delete Invalid Yearcards"
    };

    private List<SettingDto> appSettings = new();
    private bool appSettingsInitialized = false;
    private string appSettingsMessage = string.Empty;
    private bool appSettingsSuccess = false;

    // Terms editor state
    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    private string editorMessage = string.Empty;
    private bool editorSuccess = false;
    private bool editorInitialized = false;
    private bool BoldActive = false;
    private bool BulletsActive = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadAppSettings();
    }

    private string GetTabClass(AdminSection section) => section == CurrentSection ? "btn-primary" : "btn-outline-secondary";

    private async Task ChangeSection(AdminSection section)
    {
        CurrentSection = section;
        if (section == AdminSection.AppSettings)
        {
            await LoadAppSettings();
        }
    }

    private string FormatSettingLabel(string key)
    {
        return SettingLabels.TryGetValue(key, out var label) ? label : key;
    }

    private async Task LoadAppSettings()
    {
        if (appSettingsInitialized)
            return;

        appSettingsInitialized = true;
        appSettingsMessage = string.Empty;

        try
        {
            var loaded = await SettingsService.GetSettingsAsync();
            var result = loaded.ToList();

            foreach (var key in KnownKeys)
            {
                if (!result.Any(s => string.Equals(s.Key, key, StringComparison.OrdinalIgnoreCase)))
                {
                    result.Add(new SettingDto { Key = key, Value = string.Empty });
                }
            }

            appSettings = result.OrderBy(s =>
            {
                var index = Array.IndexOf(KnownKeys, s.Key);
                return index < 0 ? int.MaxValue : index;
            }).ThenBy(s => s.Key).ToList();
        }
        catch (Exception ex)
        {
            appSettingsMessage = L["Unable to load app settings:"] + $" {ex.Message}";
            appSettingsSuccess = false;
            appSettings = KnownKeys.Select(key => new SettingDto { Key = key, Value = string.Empty }).ToList();
        }
    }

    private async Task SaveAppSettings()
    {
        appSettingsMessage = string.Empty;

        try
        {
            foreach (var setting in appSettings)
            {
                await SettingsService.UpsertSettingAsync(setting.Key, setting.Value ?? string.Empty);
            }

            appSettingsSuccess = true;
            appSettingsMessage = L["App settings saved successfully."];
        }
        catch (Exception ex)
        {
            appSettingsSuccess = false;
            appSettingsMessage = L["Save failed:"] + $" {ex.Message}";
        }
    }

    private async Task ChangeAdminPassword()
    {
        var (success, message) = await AuthService.ChangePasswordAsync(adminPasswordModel);
        adminPasswordSuccess = success;
        adminPasswordMessage = success ? L["Password changed successfully!"] : message;
    }

    private async Task ChangeBartenderPassword()
    {
        var (success, message) = await AuthService.ChangePasswordAsync(bartenderPasswordModel);
        bartenderPasswordSuccess = success;
        bartenderPasswordMessage = success ? L["Password changed successfully!"] : message;
    }

    private async Task UpdateCommandStates()
    {
        try
        {
            BoldActive = await JS.InvokeAsync<bool>("authHelpers.queryCommandState", "bold", "termsEditor");
            BulletsActive = await JS.InvokeAsync<bool>("authHelpers.queryCommandState", "insertUnorderedList", "termsEditor");
            StateHasChanged();
        }
        catch { }
    }

    private async Task ExecAndUpdate(string cmd)
    {
        try
        {
            await JS.InvokeAsync<bool>("authHelpers.execAndGetState", cmd, "termsEditor");
            await UpdateCommandStates();
        }
        catch { }
    }

    private Task ExecBold() => ExecAndUpdate("bold");
    private Task ExecBullets() => ExecAndUpdate("insertUnorderedList");

    private async Task ClearTerms()
    {
        await JS.InvokeVoidAsync("authHelpers.setEditorContent", "termsEditor", string.Empty);
        editorSuccess = true;
        editorMessage = L["Terms cleared."];
    }

    private async Task SaveTermsToServer()
    {
        editorMessage = string.Empty;
        try
        {
            var html = await JS.InvokeAsync<string>("authHelpers.getEditorContent", "termsEditor");
            if (string.IsNullOrWhiteSpace(html))
            {
                editorSuccess = false;
                editorMessage = L["Cannot save empty terms."];
                return;
            }

            string token = string.Empty;
            try { token = await AuthService.GetTokenAsync(); } catch { token = string.Empty; }

            var req = new HttpRequestMessage(HttpMethod.Put, "/api/terms")
            {
                Content = new StringContent(html ?? string.Empty, System.Text.Encoding.UTF8, "text/html")
            };
            if (!string.IsNullOrEmpty(token)) req.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var resp = await Http.SendAsync(req);
            if (resp.IsSuccessStatusCode)
            {
                editorSuccess = true;
                editorMessage = L["Saved terms to server."];
            }
            else
            {
                editorSuccess = false;
                var err = await resp.Content.ReadAsStringAsync();
                editorMessage = L["Save failed:"] + $" {(int)resp.StatusCode} {err}";
            }
        }
        catch (Exception ex)
        {
            editorSuccess = false;
            editorMessage = L["Save error:"] + $" {ex.Message}";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !editorInitialized)
        {
            editorInitialized = true;
            try
            {
                try
                {
                    var resp = await Http.GetAsync("/api/terms");
                    if (resp.IsSuccessStatusCode)
                    {
                        var html = await resp.Content.ReadAsStringAsync();
                        if (!string.IsNullOrWhiteSpace(html))
                        {
                            await JS.InvokeVoidAsync("authHelpers.setEditorContent", "termsEditor", html);
                        }
                    }
                    else
                    {
                        var staticHtml = await Http.GetStringAsync("/papaterms.html");
                        if (!string.IsNullOrWhiteSpace(staticHtml))
                        {
                            await JS.InvokeVoidAsync("authHelpers.setEditorContent", "termsEditor", staticHtml);
                        }
                    }
                }
                catch
                {
                    try
                    {
                        var staticHtml = await Http.GetStringAsync("/papaterms.html");
                        if (!string.IsNullOrWhiteSpace(staticHtml))
                        {
                            await JS.InvokeVoidAsync("authHelpers.setEditorContent", "termsEditor", staticHtml);
                        }
                    }
                    catch
                    {
                        // ignore
                    }
                }
            }
            catch
            {
                // ignore; editor will remain empty
            }
            StateHasChanged();
        }
    }
}
