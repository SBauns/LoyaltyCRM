@page "/yearcard/create"
@inject YearcardService yearcards
@using System.Net.Http.Json
@using System.ComponentModel.DataAnnotations
@using LoyaltyCRM.WebApp.Components
@using LoyaltyCRM.WebApp.Locales
@inject IStringLocalizer<Resources> L
@inject NavigationManager Navigation
@inject AuthService AuthService
@inject IJSRuntime JS
@inject System.Net.Http.HttpClient Http

<div class="create-wrapper d-flex flex-column align-items-center justify-content-center min-vh-100">
    <div class="card shadow-sm p-4 w-100" style="max-width: 600px;">
        @if (CreatedYearcard == null)
        {
            <h3 class="text-center mb-3">@L["Create Yearcard"]</h3>

            <EditForm Model="@Yearcard" OnSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <div class="mb-3">
                            <label for="Name" class="form-label">@L["Name"]*</label>
                            <InputText id="Name" class="form-control" @bind-Value="Yearcard.Name" />
                        </div>
                        <div class="mb-3">
                            <label for="UserName" class="form-label">@L["Username"]</label>
                            <InputText id="UserName" class="form-control" @bind-Value="Yearcard.UserName" />
                        </div>
                        <div class="mb-3 d-flex align-items-center gap-2">
                            <input class="form-check-input" type="checkbox" id="acceptTerms" @bind="AcceptedTerms" style="margin-right: 0.5em;" />
                            <button type="button" class="btn btn-link p-0 align-baseline" style="text-decoration:underline; color:inherit; font-weight:normal;" @onclick="ShowTermsModal">
                                @L["I Accept the Terms and Agreement"]
                            </button>
                        </div>
                    </div>
                    <div class="col-12 col-md-6">
                        <div class="mb-3">
                            <label for="PhoneNumber" class="form-label">@L["Phone"]*</label>
                            <div class="input-group">
                                <CountryCodeSelector @bind-SelectedCountryCode="SelectedCountryCode"></CountryCodeSelector>
                                <InputText id="PhoneNumber" class="form-control" @bind-Value="PhoneNumberInput" oninput="this.value=this.value.replace(/[^0-9]/g,'')" inputmode="numeric" pattern="[0-9]*" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="Email" class="form-label">@L["Email"]*</label>
                            <InputText id="Email" class="form-control" @bind-Value="Yearcard.Email" />
                        </div>
                        <div class="mb-3 d-flex align-items-center gap-2">
                            <input class="form-check-input" type="checkbox" id="isgift" @bind="IsGiftCard" style="margin-right: 0.5em;" />
                            <label for="isgift" class="form-label mb-0">@L["It is a gift"]*</label>
                        </div>
                        @if (IsGiftCard)
                        {
                            <div class="mb-3">
                                <label for="startDate" class="form-label">@L["From whence shall this card be active from?"]</label>
                                <input type="date" id="startDate" class="form-control" @bind="Yearcard.StartDate" min="@TodayString" />
                            </div>
                        }
                    </div>
                </div>
                <button type="submit" class="btn btn-primary w-100 mt-2" disabled="@(!EverythingIsValid())">@L["Create Yearcard"]</button>
            </EditForm>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Message))
            {
                <h1 class="alert alert-success mt-3 text-center">@L[Message]</h1>
            }
            <YearcardDisplay Yearcard="CreatedYearcard" />
            <h1 class="alert alert-success mt-3 text-center">@L["Please return the tablet to the bartender"]</h1>
        }


        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger mt-3 text-center">@L["An error occurred:"] @L[ErrorMessage]</div>
        }

        @if (ShowModal)
        {
            <div class="modal-overlay">
                <div class="modal-content">
                    <h5>@L["Terms and Agreement"]</h5>
                    <div style="border:none; width:100%; height:400px; overflow:auto;" class="terms-content">
                        @((MarkupString)TermsHtml)
                    </div>
                        <button class="btn btn-secondary mt-3" @onclick="HideTermsModal">@L["Close"]</button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private YearcardDTO Yearcard { get; set; } = new YearcardDTO();
    private YearcardDTO? CreatedYearcard { get; set; }
    private string Message { get; set; } = string.Empty;
    private string ErrorMessage { get; set; } = string.Empty;
    private bool AcceptedTerms { get; set; } = false;
    private bool IsGiftCard { get; set; } = false;
    private bool ShowModal { get; set; } = false;
    private string TermsHtml { get; set; } = string.Empty;
    private string TodayString => DateTime.Today.ToString("yyyy-MM-dd");

    // Country code selector

    private string PhoneNumberInput = string.Empty;
    private string SelectedCountryCode { get; set; } = "+45";

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        ResetForm();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // Only reset if navigating to this page
        var uri = Navigation.ToBaseRelativePath(e.Location);
        if (uri.StartsWith("yearcard/create", StringComparison.OrdinalIgnoreCase))
        {
            ResetForm();
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private async Task HandleSubmit(EditContext context)
    {
        // Combine country code and phone number
        try
        {
            Yearcard.PhoneNumber = PhoneNumberInput;
            if (context.Validate() && EverythingIsValid())
            {
                // Combine country code and phone number
                Yearcard.PhoneNumber = SelectedCountryCode + "-" + PhoneNumberInput;
                CreatedYearcard = await yearcards.CreateYearcardAsync(Yearcard);
                Message = ("Yearcard created successfully!");
                ErrorMessage = string.Empty;
                // ResetForm();
            }
            else{
                ErrorMessage = context.GetValidationMessages().ToList().First();
            }
        }
        catch (UnauthorizedAccessException ex)
        {
            ErrorMessage = ex.Message;
            Navigation.NavigateTo("/login", true);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private bool EverythingIsValid()
    {
        return (!string.IsNullOrEmpty(PhoneNumberInput) &&
               !string.IsNullOrEmpty(Yearcard.Email) &&
               !string.IsNullOrEmpty(Yearcard.Name)) &&
               AcceptedTerms;
    }

    private void ResetForm()
    {
        CreatedYearcard = null;
        PhoneNumberInput = string.Empty;
        Yearcard = new YearcardDTO(); // Reset the form data
        Message = string.Empty;
        ErrorMessage = string.Empty;
        SelectedCountryCode = "+45";
    }

    private async Task ShowTermsModal()
    {
        ShowModal = true;
        // Prefer terms from server API, then fall back to static file
        try
        {
            var resp = await Http.GetAsync("/api/terms");
            if (resp.IsSuccessStatusCode)
            {
                TermsHtml = await resp.Content.ReadAsStringAsync();
                StateHasChanged();
                return;
            }
        }
        catch { }

        try
        {
            TermsHtml = await Http.GetStringAsync("/papaterms.html");
        }
        catch
        {
            TermsHtml = "<p>Terms are not available. Please contact an administrator.</p>";
        }
        StateHasChanged();
    }

    private void HideTermsModal()
    {
        ShowModal = false;
        TermsHtml = string.Empty;
    }
}
