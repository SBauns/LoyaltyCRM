@page "/admin/password"
@layout AdminLayout

@using LoyaltyCRM.DTOs.DTOs
@using LoyaltyCRM.WebApp.Locales

@inject AuthService AuthService
@inject IStringLocalizer<Resources> L

<h4 class="text-center mb-3">@L["PasswordSettings.Title"]</h4>

<div class="row g-3">
    <div class="col-12 col-md-6">
        <h5 class="text-center">@L["PasswordSettings.Admin"]</h5>

        <EditForm Model="@adminPasswordModel" OnValidSubmit="ChangeAdminPassword">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">@L["PasswordSettings.AdminUsername"]</label>
                <InputText class="form-control" @bind-Value="adminPasswordModel.UserName" />
            </div>

            <div class="mb-3">
                <label class="form-label">@L["PasswordSettings.CurrentPassword"]</label>
                <InputText class="form-control" type="password"
                           @bind-Value="adminPasswordModel.CurrentPassword" />
            </div>

            <div class="mb-3">
                <label class="form-label">@L["PasswordSettings.NewPassword"]</label>
                <InputText class="form-control" type="password"
                           @bind-Value="adminPasswordModel.NewPassword" />
            </div>

            <button class="btn btn-primary w-100 mt-2">
                @L["PasswordSettings.ChangePassword"]
            </button>

            @if (!string.IsNullOrEmpty(adminPasswordMessage))
            {
                <div class="alert mt-2 @(adminPasswordSuccess ? "alert-success" : "alert-danger") text-center">
                    @adminPasswordMessage
                </div>
            }
        </EditForm>
    </div>

    <div class="col-12 col-md-6">
        <h5 class="text-center">@L["PasswordSettings.Bartender"]</h5>

        <EditForm Model="@bartenderPasswordModel" OnValidSubmit="ChangeBartenderPassword">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">@L["PasswordSettings.BartenderUsername"]</label>
                <InputText class="form-control" @bind-Value="bartenderPasswordModel.UserName" />
            </div>

            <div class="mb-3">
                <label class="form-label">@L["PasswordSettings.CurrentPassword"]</label>
                <InputText class="form-control" type="password"
                           @bind-Value="bartenderPasswordModel.CurrentPassword" />
            </div>

            <div class="mb-3">
                <label class="form-label">@L["PasswordSettings.NewPassword"]</label>
                <InputText class="form-control" type="password"
                           @bind-Value="bartenderPasswordModel.NewPassword" />
            </div>

            <button class="btn btn-primary w-100 mt-2">
                @L["PasswordSettings.ChangePassword"]
            </button>

            @if (!string.IsNullOrEmpty(bartenderPasswordMessage))
            {
                <div class="alert mt-2 @(bartenderPasswordSuccess ? "alert-success" : "alert-danger") text-center">
                    @bartenderPasswordMessage
                </div>
            }
        </EditForm>
    </div>
</div>

@code {
    private AuthService.ChangePasswordDto adminPasswordModel = new();
    private AuthService.ChangePasswordDto bartenderPasswordModel = new();

    private string adminPasswordMessage = string.Empty;
    private string bartenderPasswordMessage = string.Empty;

    private bool adminPasswordSuccess;
    private bool bartenderPasswordSuccess;

    private async Task ChangeAdminPassword()
    {
        var (success, message) = await AuthService.ChangePasswordAsync(adminPasswordModel);
        adminPasswordSuccess = success;
        adminPasswordMessage = success
            ? L["PasswordSettings.ChangedSuccessfully"]
            : message;
    }

    private async Task ChangeBartenderPassword()
    {
        var (success, message) = await AuthService.ChangePasswordAsync(bartenderPasswordModel);
        bartenderPasswordSuccess = success;
        bartenderPasswordMessage = success
            ? L["PasswordSettings.ChangedSuccessfully"]
            : message;
    }
}