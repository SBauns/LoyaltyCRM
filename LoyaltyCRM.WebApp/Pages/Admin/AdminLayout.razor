@layout MainLayout
@inherits LayoutComponentBase
@using LoyaltyCRM.WebApp.Locales
@inject IStringLocalizer<Resources> L

<div class="wrapper d-flex flex-column align-items-center justify-content-center vh-80">
    <div class="card shadow-sm p-4 w-100" style="max-width: 820px;">
        
        <h3 class="text-center mb-3">Admin Panel</h3>

        <div class="btn-group w-100 mb-4" role="group">
            <NavLink class="btn btn-outline-secondary" href="/admin/password">@L["Password settings"]</NavLink>
            <NavLink class="btn btn-outline-secondary" href="/admin/terms">@L["Terms setting"]</NavLink>
            <NavLink class="btn btn-outline-secondary" href="/admin/app">@L["App settings"]</NavLink>
            <NavLink class="btn btn-outline-secondary" href="/admin/import">@L["Import users"]</NavLink>
        </div>

        @Body
    </div>
</div>